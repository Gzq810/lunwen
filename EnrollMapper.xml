<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.EnrollMapper">

    <select id="selectAll" resultType="com.example.entity.Enroll">
        select enroll.*, activity.name as activityName, user.name as userName from `enroll`
        left join activity on enroll.activity_id = activity.id
        left join user on enroll.user_id = user.id
        <where>
            <if test="activityName != null"> and activity.name like concat('%', #{activityName}, '%')</if>
            <if test="userId != null"> and enroll.user_id = #{userId}</if>
        </where>
        order by enroll.id desc
    </select>

    <delete id="deleteById">
        delete from `enroll`
        where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.example.entity.Enroll" useGeneratedKeys="true">
        insert into `enroll`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="activityId != null">activity_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="time != null">time,</if>
            <if test="status != null">status,</if>
            <if test="reason != null">reason,</if>
            <if test="name != null">name,</if>
            <if test="phone != null">phone,</if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="activityId != null">#{activityId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="time != null">#{time},</if>
            <if test="status != null">#{status},</if>
            <if test="reason != null">#{reason},</if>
            <if test="name != null">#{name},</if>
            <if test="phone != null">#{phone},</if>
        </trim>


    </insert>

    <update id="updateById" parameterType="com.example.entity.Enroll">
        update `enroll`
        <set>
            <if test="id != null">
                id = #{id},
            </if>
            <if test="activityId != null">
                activity_id = #{activityId},
            </if>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="time != null">
                time = #{time},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="reason != null">
                reason = #{reason},
            </if>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="phone != null">
                phone = #{phone},
            </if>
        </set>
        where id = #{id}


    </update>

</mapper>